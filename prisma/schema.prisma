generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reservation {
  id              Int               @id @default(autoincrement())
  barberId        Int               @map("barber_id")
  clientId        Int               @map("client_id")
  serviceId       Int               @map("service_id")
  startTime       DateTime          @map("start_time") @db.Timestamptz(6)
  endTime         DateTime          @map("end_time") @db.Timestamptz(6)
  notes           String?
  status          ReservationStatus @default(SCHEDULED)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  durationMinutes Int
  priceAtBooking  Decimal           @map("price_at_booking") @db.Decimal(10, 0)
  createdBy       Int?              @map("created_by")
  updatedBy       Int?              @map("updated_by")
  barber          Barber            @relation(fields: [barberId], references: [userId], onDelete: Cascade)
  client          User              @relation("ClientReservations", fields: [clientId], references: [id], onDelete: Cascade)
  service         Service           @relation(fields: [serviceId], references: [id])

  @@index([barberId, startTime, endTime])
  @@index([status])
  @@map("reservations")
}

model Barber {
  userId          Int           @id @map("user_id")
  experienceYears Int           @map("experience_years")
  bio             String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy       Int?          @map("created_by")
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy       Int?          @map("updated_by")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations    Reservation[]

  @@map("barbers")
}

model Service {
  id              Int           @id @default(autoincrement())
  name            String        @db.VarChar(50)
  description     String?
  price           Decimal       @db.Decimal(10, 2)
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  durationMinutes Int
  createdBy       Int?          @map("created_by")
  updatedBy       Int?          @map("updated_by")
  reservations    Reservation[]

  @@index([isActive])
  @@map("services")
}

model User {
  id                 Int           @id @default(autoincrement())
  fullName           String        @map("full_name") @db.VarChar(100)
  email              String        @unique @db.VarChar(100)
  password           String        @db.VarChar(255)
  role               UserRole      @default(CLIENT)
  status             UserStatus    @default(ACTIVE)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy          Int?          @map("created_by")
  updatedBy          Int?          @map("updated_by")
  barber             Barber?
  clientReservations Reservation[] @relation("ClientReservations")

  @@index([role])
  @@map("users")
}

enum ReservationStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("reservations_status")
}

enum UserRole {
  CLIENT
  BARBER
  ADMIN

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED

  @@map("user_status")
}
